# ============================================================
# CrackBackend — Variables de entorno
# Copiar este archivo como .env y completar los valores.
# NUNCA commitear el .env real al repositorio.
# ============================================================

# Django
SECRET_KEY=cambia-esto-por-una-clave-segura
DEBUG=True

# URL del frontend (para CORS en producción)
FRONTEND_URL=https://tu-frontend.vercel.app

# URL base del sitio (para links en emails, SEO)
SITE_URL=https://tu-backend.onrender.com

# ============================================================
# Base de datos
# ============================================================
# Dejar vacío en desarrollo (usa SQLite automáticamente).
# En Render, setear con la URL de la DB de PostgreSQL:
#   DATABASE_URL=postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# ============================================================
# MercadoPago
# ============================================================
# Token del cliente (obtenerlo desde el panel de MP del cliente)
MP_ACCESS_TOKEN=

# ============================================================
# Email — Resend
# ============================================================
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=no-reply@tudominio.com

# ============================================================
# Cache — Upstash Redis (solo producción)
# ============================================================
# Setear USE_UPSTASH=true en Render y completar las credenciales.
USE_UPSTASH=false
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================
# Render (se setea automáticamente en el deploy)
# ============================================================
RENDER_EXTERNAL_HOSTNAME=
